# ── Database ─────────────────────────────────────────────
# Railway PostgreSQL plugin auto-sets DATABASE_URL
# Or paste your PostgreSQL connection string here:
DATABASE_URL=postgresql://user:password@host:5432/dbname

# ── App ──────────────────────────────────────────────────
SECRET_KEY=change-this-to-a-random-secret-key-in-production

# Admin account (auto-created on first run)
ADMIN_EMAIL=admin@spoteasy.in
ADMIN_PASSWORD=Admin@1234

# ── Email (Gmail SMTP) ───────────────────────────────────
# Optional - for booking confirmation emails
EMAIL_FROM=your-gmail@gmail.com
EMAIL_KEY=your-gmail-app-password

# ── Railway (auto-set by Railway, do NOT set manually) ───
# RAILWAY_PUBLIC_DOMAIN  →  set automatically by Railway
# PORT                   →  set automatically by Railway

# ── Custom domain (optional override) ───────────────────
# SITE_URL=https://www.spoteasy.in
